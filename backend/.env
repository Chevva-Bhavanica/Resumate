# ------------------------
# App Settings
# ------------------------
APP_NAME=Resumate
APP_ENV=development
APP_PORT=8000

# ------------------------
# MongoDB Settings
# ------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB=resumate_db

# ------------------------
# JWT Settings
# ------------------------
SECRET_KEY=your_super_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------
# CORS Settings
# ------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ------------------------
# Other Settings (optional)
# ------------------------
LOG_LEVEL=info
