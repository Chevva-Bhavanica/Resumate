# ------------------------
# Application
# ------------------------
APP_NAME=Resumate API
APP_VERSION=1.0.0
DEBUG=True

# ------------------------
# SQL Database (SQLite for dev)
# ------------------------
SQLALCHEMY_DATABASE_URL=sqlite:///./resumate.db
# For PostgreSQL:
# SQLALCHEMY_DATABASE_URL=postgresql://user:password@localhost:5432/resumate_db

# ------------------------
# JWT
# ------------------------
SECRET_KEY=your-super-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ------------------------
# CORS
# ------------------------
ALLOWED_ORIGINS=http://localhost:3000

# ------------------------
# File Upload
# ------------------------
MAX_FILE_SIZE_MB=5
ALLOWED_FILE_TYPES=application/pdf
